# UrbanFix AI Service — Environment Variables
# Copy to .env and fill in values

# API key for securing the endpoint (Node.js backend sends this)
AI_API_KEY=your-secret-key-here

# CORS origins (comma-separated)
AI_CORS_ORIGINS=http://localhost:5000,http://localhost:3000

# Device override (auto-detects GPU if available)
# AI_DEVICE=cpu

# --- Road damage YOLO (same pipeline as Colab UrbanFix_AI_Notebook) ---
# Optional: absolute path to your trained weights (e.g. after Colab training).
# In Docker, copy road_damage_best.pt into the image (e.g. models/road_damage_best.pt) and set:
#   AI_ROAD_WEIGHTS_PATH=/app/models/road_damage_best.pt
# If unset, the service downloads from HuggingFace (road_hf_repo in config).
# Example (your trained road YOLO from Colab):
# AI_ROAD_WEIGHTS_PATH=c:/Work/Projects/App/appv1/colab/best.pt
# AI_ROAD_WEIGHTS_PATH=
# AI_ROAD_HF_REPO=ozair23/yolov8-road-damage-detector

# Model confidence thresholds
# AI_VALIDATION_THRESHOLD=0.55
# AI_DETECTION_CONFIDENCE=0.15
# AI_YOLO_WORLD_CONFIDENCE=0.10

# Router + specialist fusion (full = merge SigLIP with road/trash/flood/YOLO-World; best category accuracy)
# AI_FUSION_MODE=full
# AI_FUSION_ROUTER_WEIGHT=0.32
# AI_FUSION_SPECIALIST_WEIGHT=0.68
# AI_FUSION_PENALIZE_OTHER=true

# Overlap merge for duplicate YOLO boxes (same class). 0 = off.
# AI_DETECTION_NMS_IOU=0.45
